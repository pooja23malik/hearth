# Database (used by docker-compose, defaults work for local dev)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=family_tasks

# App (set DATABASE_URL only if running outside Docker)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/family_tasks?schema=public

# LLM (Ollama running on the host machine)
# Inside Docker: http://host.docker.internal:11434 (set automatically by docker-compose)
# Outside Docker: http://localhost:11434
# LLM_ENDPOINT=http://localhost:11434
# LLM_MODEL=gemma4:26b
