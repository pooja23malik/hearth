generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Board {
  id           String   @id @default(uuid())
  name         String
  invite_token String   @unique @default(uuid())
  timezone     String?
  created_at   DateTime @default(now())

  members Member[]
  tasks   Task[]
  values  BoardValue[]
  digests WeeklyDigest[]

  @@map("boards")
}

model Member {
  id           String   @id @default(uuid())
  board_id     String
  name         String
  avatar_color String
  is_creator   Boolean  @default(false)
  active       Boolean  @default(true)
  created_at   DateTime @default(now())

  last_viewed_digest_week DateTime?

  board             Board         @relation(fields: [board_id], references: [id], onDelete: Cascade)
  created_tasks     Task[]        @relation("TaskCreator")
  assigned_tasks    Task[]        @relation("TaskAssignee")
  completed_tasks   Task[]        @relation("TaskCompleter")
  task_completions  TaskHistory[] @relation("HistoryCompleter")

  @@unique([board_id, name])
  @@map("members")
}

enum TaskCategory {
  home_maintenance
  health
  errands
  personal
  other
}

enum TimeOfDay {
  morning
  afternoon
  evening
  anytime
}

enum RecurrenceRule {
  daily
  weekly
  biweekly
  monthly
  every_3_months
  every_6_months
  yearly
}

enum TaskStatus {
  pending
  completed
}

model Task {
  id                        String          @id @default(uuid())
  board_id                  String
  title                     String
  description               String?
  category                  TaskCategory    @default(other)
  estimated_duration_minutes Int?
  assigned_to               String?
  is_personal               Boolean         @default(false)
  preferred_time_of_day     TimeOfDay       @default(anytime)
  recurrence_rule           RecurrenceRule?
  next_due_date             DateTime?       @db.Date
  status                    TaskStatus      @default(pending)
  created_by                String
  created_at                DateTime        @default(now())
  completed_at              DateTime?
  completed_by              String?

  board     Board    @relation(fields: [board_id], references: [id], onDelete: Cascade)
  creator   Member   @relation("TaskCreator", fields: [created_by], references: [id])
  assignee  Member?  @relation("TaskAssignee", fields: [assigned_to], references: [id])
  completer Member?  @relation("TaskCompleter", fields: [completed_by], references: [id])
  history   TaskHistory[]

  @@map("tasks")
}

model TaskHistory {
  id           String   @id @default(uuid())
  task_id      String
  board_id     String
  completed_by String
  completed_at DateTime @default(now())
  notes        String?

  task      Task   @relation(fields: [task_id], references: [id], onDelete: Cascade)
  completer Member @relation("HistoryCompleter", fields: [completed_by], references: [id])

  @@map("task_history")
}

model BoardValue {
  id         String       @id @default(uuid())
  board_id   String
  name       String
  category   TaskCategory
  priority   Int
  created_at DateTime     @default(now())

  board  Board              @relation(fields: [board_id], references: [id], onDelete: Cascade)
  scores DigestValueScore[]

  @@unique([board_id, category])
  @@map("board_values")
}

model WeeklyDigest {
  id         String   @id @default(uuid())
  board_id   String
  week_start DateTime
  total_tasks_due       Int @default(0)
  total_tasks_completed Int @default(0)
  created_at DateTime @default(now())

  board    Board              @relation(fields: [board_id], references: [id], onDelete: Cascade)
  scores   DigestValueScore[]
  insights DigestInsight[]

  @@unique([board_id, week_start])
  @@map("weekly_digests")
}

model DigestValueScore {
  id              String @id @default(uuid())
  digest_id       String
  value_id        String
  tasks_due       Int
  tasks_completed Int
  alignment_pct   Float?

  digest WeeklyDigest @relation(fields: [digest_id], references: [id], onDelete: Cascade)
  value  BoardValue   @relation(fields: [value_id], references: [id], onDelete: Cascade)

  @@map("digest_value_scores")
}

model DigestInsight {
  id        String @id @default(uuid())
  digest_id String
  type      String
  text      String

  digest WeeklyDigest @relation(fields: [digest_id], references: [id], onDelete: Cascade)

  @@map("digest_insights")
}
